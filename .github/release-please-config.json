{
  "packages": {
    "trymsae.memeshell": {
      "release-type": "simple",
      "package-name": "trymsae.memeshell",
      "pull-request-title-pattern": "🍺 chore: release ${component} ${version}",
      "pull-request-header": "lmaooo, new release.",
      "pull-request-footer": "---\n\nMerge this PR to trigger the release and build pipeline.",
      "include-v-in-tag": true,
      "changelog-sections": [
        {"type": "feat", "section": "Features"},
        {"type": "fix", "section": "Bug Fixes"},
        {"type": "chore", "section": "Miscellaneous", "hidden": false}
      ]
    }
  }
}
